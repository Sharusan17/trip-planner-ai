DATABASE_URL=postgresql://localhost:5432/trip_planner_dev
PORT=3001
NODE_ENV=development

# Exchange rate API (open.er-api.com — free tier, no key required)
# Leave blank to use the free unauthenticated endpoint
EXCHANGE_RATE_API_KEY=

# Tabscanner receipt OCR — get a free key at https://tabscanner.com
TABSCANNER_API_KEY=

# LiteAPI hotel search — get a free key at https://liteapi.travel
LITEAPI_API_KEY=

# Aviationstack flight lookup & route search — get a free key at https://aviationstack.com
# Free tier: 10 000 calls/month. Airport autocomplete uses a static cache (no calls needed).
# Flight lookup works for current-day and past flights. Future flights need a paid plan.
AVIATIONSTACK_API_KEY=