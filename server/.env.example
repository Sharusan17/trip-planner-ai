DATABASE_URL=postgresql://localhost:5432/trip_planner_dev
PORT=3001
NODE_ENV=development

# Exchange rate API (open.er-api.com — free tier, no key required)
# Leave blank to use the free unauthenticated endpoint
EXCHANGE_RATE_API_KEY=

# Tabscanner receipt OCR — get a free key at https://tabscanner.com
TABSCANNER_API_KEY=

# LiteAPI hotel search — get a free key at https://liteapi.travel
LITEAPI_API_KEY=

# FlightAPI.io flight lookup + live status — get a key at https://flightapi.io
# Supports querying any date via `date=YYYYMMDD`. Better coverage for budget carriers than Aviationstack.
FLIGHTAPI_KEY=

# Airport autocomplete uses a static dataset cached in memory — no API key needed.