{
  "name": "trip-planner-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "dashboard"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=dashboard",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=dashboard",
    "start": "node server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
